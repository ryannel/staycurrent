{
  "schema": "groundwork.brand-tokens",
  "version": 1,
  "tier": 2,
  "identity": {
    "appName": "Stay Current",
    "wordmark": "●",
    "primary": "#0e6936",
    "accent": "#865901",
    "voice": "quiet authority; declarative, stance-first; dates and versions wherever trust needs them"
  },
  "visual": {
    "palette": {
      "primary":    { "light": "oklch(46% 0.115 152)", "dark": "oklch(76% 0.140 152)" },
      "accent":     { "light": "oklch(50% 0.105 75)",  "dark": "oklch(74% 0.105 78)" },
      "surface":    { "light": "oklch(97.5% 0.007 85)", "dark": "oklch(16.5% 0.010 80)" },
      "surfaceAlt": { "light": "oklch(95.3% 0.009 85)", "dark": "oklch(19.5% 0.012 80)" },
      "textBody":   { "light": "oklch(24% 0.018 75)",  "dark": "oklch(87% 0.010 85)" },
      "success":    { "light": "oklch(46% 0.115 152)", "dark": "oklch(76% 0.140 152)" },
      "error":      { "light": "oklch(47% 0.150 30)",  "dark": "oklch(72% 0.140 30)" },
      "warning":    { "light": "oklch(50% 0.105 75)",  "dark": "oklch(74% 0.105 78)" },
      "info":       { "light": "oklch(44% 0.014 75)",  "dark": "oklch(68% 0.012 80)" }
    },
    "typography": {
      "display": { "family": "Literata", "weight": 550 },
      "body":    { "family": "Literata", "weight": 400 },
      "scale": "fluid clamp essay scale (17-19px serif body); fixed Inter chrome (14/13px); JetBrains Mono trust data (13px)",
      "roles": {
        "display": { "size": "clamp(2.125rem, 1.55rem + 2.2vw, 3rem)", "lineHeight": 1.12, "weight": 550, "tracking": "-0.015em" },
        "title":   { "size": "clamp(1.5rem, 1.28rem + 0.8vw, 1.75rem)", "lineHeight": 1.25, "weight": 600, "tracking": "0" },
        "body":    { "size": "clamp(1.0625rem, 1rem + 0.3vw, 1.1875rem)", "lineHeight": 1.72, "weight": 400, "tracking": "0" },
        "caption": { "size": "0.8125rem", "lineHeight": 1.45, "weight": 450, "tracking": "0" },
        "label":   { "size": "0.6875rem", "lineHeight": 1.2, "weight": 600, "tracking": "0.08em" }
      },
      "numeric": "tabular-nums"
    },
    "shape": { "radiusBase": "6px", "character": "quiet, controls-only rounding; concentric overlays at 10px" },
    "density": "spacious 72ch essays, instrument-dense trust metadata; 8pt grid with 4px half-step",
    "motion": {
      "easeStandard": "cubic-bezier(0.2, 0, 0, 1)",
      "durationBaseMs": 180,
      "personality": "restrained",
      "interactions": {
        "hover": { "durationMs": 120, "ease": "cubic-bezier(0.2, 0, 0, 1)", "transform": "none" },
        "press": { "durationMs": 60,  "ease": "cubic-bezier(0.2, 0, 0, 1)", "transform": "scale(0.985)" },
        "enter": { "durationMs": 120, "ease": "cubic-bezier(0.2, 0, 0, 1)", "transform": "translateY(-4px)" },
        "exit":  { "durationMs": 180, "ease": "cubic-bezier(0.4, 0, 1, 1)", "transform": "none" }
      }
    },
    "elevation": {
      "overlay": [
        { "y": "1px", "blur": "2px",  "color": "oklch(20% 0.015 80 / 0.07)" },
        { "y": "6px", "blur": "16px", "color": "oklch(20% 0.015 80 / 0.11)" },
        { "y": "0",   "blur": "0", "spread": "1px", "color": "oklch(20% 0.015 80 / 0.05)" }
      ],
      "drawer": [
        { "y": "2px",  "blur": "4px",  "color": "oklch(20% 0.015 80 / 0.08)" },
        { "y": "12px", "blur": "32px", "color": "oklch(20% 0.015 80 / 0.16)" }
      ]
    },
    "references": [
      { "name": "Stripe Docs", "admired": "fixed-size sans chrome against fluid body, scroll-spy TOC rail, code blocks as designed objects" },
      { "name": "gwern.net", "admired": "per-essay metadata block as instrumentation; ~70ch measure, 1.7+ line-height" },
      { "name": "Linear Changelog", "admired": "self-contained permalinked entries; accent under 5% of any view; 120-200ms functional motion" },
      { "name": "iA", "admired": "editorial serif at screen scale on warm near-white; hairline rules; no content shadows" },
      { "name": "Keep a Changelog", "admired": "fixed entry anatomy parseable by machine, comfortable for humans" }
    ]
  }
}
