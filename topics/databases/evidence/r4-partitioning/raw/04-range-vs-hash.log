=== Experiment 4: range vs hash under a time-ordered stream — Fri Jul 24 09:40:03 SAST 2026 ===

--- two tables, 12 partitions each, on the same key ---

$ psql -c "DROP TABLE IF EXISTS ev_range; CREATE TABLE ev_range (id bigint, occurred_at timestamptz NOT NULL) PARTITION BY RANGE (occurred_at);"
NOTICE:  table "ev_range" does not exist, skipping
DROP TABLE
CREATE TABLE

$ psql -c "DROP TABLE IF EXISTS ev_hash; CREATE TABLE ev_hash (id bigint, occurred_at timestamptz NOT NULL) PARTITION BY HASH (occurred_at);"
NOTICE:  table "ev_hash" does not exist, skipping
DROP TABLE
CREATE TABLE
created ev_range (12 monthly range partitions) and ev_hash (12 hash partitions)

--- the stream: 120,000 rows, strictly increasing, all inside ONE day ---
--- (this is what 'today's writes' looks like to a table partitioned by month) ---

$ psql -c "INSERT INTO ev_range (id, occurred_at) SELECT g, timestamptz '2025-07-15 00:00:00' + (g || ' milliseconds')::interval FROM generate_series(1, 120000) g;"
INSERT 0 120000

$ psql -c "INSERT INTO ev_hash (id, occurred_at) SELECT g, timestamptz '2025-07-15 00:00:00' + (g || ' milliseconds')::interval FROM generate_series(1, 120000) g;"
INSERT 0 120000

--- where the rows landed: RANGE ---

$ psql -c "SELECT tableoid::regclass AS partition, count(*) FROM ev_range GROUP BY 1 ORDER BY 2 DESC;"
  partition  | count  
-------------+--------
 ev_range_07 | 120000
(1 row)


