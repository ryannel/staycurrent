================================================================
=== C. the aftermath — what each approach left behind
================================================================

$ psql -c "SELECT relname, n_live_tup, n_dead_tup, last_vacuum, last_autovacuum FROM pg_stat_user_tables WHERE relname = 'events_flat';"
   relname   | n_live_tup | n_dead_tup |          last_vacuum          | last_autovacuum 
-------------+------------+------------+-------------------------------+-----------------
 events_flat |    1808121 |     591839 | 2026-07-24 07:38:23.554227+00 | 
(1 row)


$ psql -c "SELECT pg_size_pretty(pg_total_relation_size('events_flat')) AS flat_size_after_delete;"
 flat_size_after_delete 
------------------------
 208 MB
(1 row)


$ psql -c "SELECT pg_size_pretty(sum(pg_total_relation_size(c.oid))) AS remaining_partitions_total FROM pg_class c JOIN pg_inherits i ON i.inhrelid = c.oid WHERE i.inhparent = 'events'::regclass;"
 remaining_partitions_total 
----------------------------
 157 MB
(1 row)


--- and what VACUUM does or does not give back ---

$ psql -c "\timing on" -c "VACUUM events_flat;"
Timing is on.
VACUUM
Time: 101.718 ms

$ psql -c "SELECT relname, n_live_tup, n_dead_tup FROM pg_stat_user_tables WHERE relname = 'events_flat';"
