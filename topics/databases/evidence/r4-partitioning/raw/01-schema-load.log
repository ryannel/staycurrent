--- the unpartitioned twin: identical columns, identical rows ---

$ psql -c "CREATE TABLE events_flat (id bigserial, occurred_at timestamptz NOT NULL, tenant_id int NOT NULL, payload text);"
CREATE TABLE

--- load: 200,000 rows per month across 2025, evenly spread within each month ---
$ INSERT ... generate_series over 12 months x 200000
INSERT 0 2400000

$ psql -c "INSERT INTO events_flat (occurred_at, tenant_id, payload) SELECT occurred_at, tenant_id, payload FROM events;"
