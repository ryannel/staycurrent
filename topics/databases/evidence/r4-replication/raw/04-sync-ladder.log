=== Experiment 4: the synchronous_commit ladder — Fri Jul 24 09:34:23 SAST 2026 ===

--- step 1: the table under test, and the pgbench script (one INSERT per transaction) ---

$ psql@primary -c "DROP TABLE IF EXISTS ledger;"
DROP TABLE

$ psql@primary -c "CREATE TABLE ledger (id serial PRIMARY KEY, payload text);"
CREATE TABLE

$ cat /tmp/bench.sql
INSERT INTO ledger (payload) VALUES ('x');

--- step 2: before — no synchronous standby is named, so both replicas are async ---

$ psql@primary -c "ALTER SYSTEM RESET synchronous_standby_names;"
ALTER SYSTEM

$ psql@primary -c "SELECT pg_reload_conf();"
 pg_reload_conf 
----------------
 t
(1 row)


$ psql@primary -c "SHOW synchronous_standby_names;"
 synchronous_standby_names 
---------------------------
 
(1 row)


$ psql@primary -c "SELECT application_name, sync_state FROM pg_stat_replication ORDER BY application_name;"
 application_name | sync_state 
------------------+------------
 sba              | async
 sbb              | async
(2 rows)


--- step 3: name standby A as the synchronous standby (each ALTER SYSTEM its own -c) ---

$ psql@primary -c "ALTER SYSTEM SET synchronous_standby_names = 'sba';"
ALTER SYSTEM

$ psql@primary -c "SELECT pg_reload_conf();"
 pg_reload_conf 
----------------
 t
(1 row)


$ psql@primary -c "SHOW synchronous_standby_names;"
 synchronous_standby_names 
---------------------------
 sba
(1 row)


$ psql@primary -c "SELECT application_name, sync_state FROM pg_stat_replication ORDER BY application_name;"
 application_name | sync_state 
------------------+------------
 sba              | sync
 sbb              | async
(2 rows)


guard: sync_state for sba = 'sync'
guard passed: standby A is synchronous, standby B remains async and is never waited on.

