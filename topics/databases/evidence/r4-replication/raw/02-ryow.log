=== Experiment 2: read-your-own-writes — Fri Jul 24 09:31:03 SAST 2026 ===

--- step 1: the table, created on the primary ---

$ psql@primary -c "DROP TABLE IF EXISTS comments; CREATE TABLE comments (id serial PRIMARY KEY, author text, body text, posted_at timestamptz DEFAULT now());"
NOTICE:  table "comments" does not exist, skipping
DROP TABLE
CREATE TABLE

--- step 2: both standbys agree the table is empty (baseline) ---

$ psql@sba -c "SELECT count(*) AS rows_on_standby_a FROM comments;"
 rows_on_standby_a 
-------------------
                 0
(1 row)


$ psql@sbb -c "SELECT count(*) AS rows_on_standby_b FROM comments;"
 rows_on_standby_b 
-------------------
                 0
(1 row)


--- step 3: pause WAL replay on standby B — this is the induced lag ---

$ psql@sbb -c "SELECT pg_wal_replay_pause();"
 pg_wal_replay_pause 
---------------------
 
(1 row)


$ psql@sbb -c "SELECT pg_is_wal_replay_paused();"
 pg_is_wal_replay_paused 
-------------------------
 t
(1 row)


--- step 4: the user posts a comment. The primary acknowledges the COMMIT. ---

$ psql@primary -c "INSERT INTO comments (author, body) VALUES ('user7', 'sentinel-9f4c22 — posted by user 7') RETURNING id, author, body;"
 id | author |                body                
----+--------+------------------------------------
  1 | user7  | sentinel-9f4c22 — posted by user 7
(1 row)

INSERT 0 1

$ psql@primary -c "SELECT count(*) AS rows_on_primary FROM comments;"
 rows_on_primary 
-----------------
               1
(1 row)


--- step 5: the user refreshes. The read is routed to standby B. ---
--- THIS IS THE ANOMALY: the write is committed and acknowledged, and the row is not here.

$ psql@sbb -c "SELECT count(*) AS rows_on_standby_b FROM comments;"
 rows_on_standby_b 
-------------------
                 0
(1 row)


$ psql@sbb -c "SELECT id, author, body FROM comments;"
 id | author | body 
----+--------+------
(0 rows)


--- step 6: control — the same read, same moment, against the streaming standby A ---

$ psql@sba -c "SELECT id, author, body FROM comments;"
 id | author |                body                
----+--------+------------------------------------
  1 | user7  | sentinel-9f4c22 — posted by user 7
(1 row)


--- step 7: how far behind standby B actually is, in bytes and in time ---

$ psql@primary -c "SELECT application_name, state, sent_lsn, replay_lsn, pg_wal_lsn_diff(sent_lsn, replay_lsn) AS replay_lag_bytes FROM pg_stat_replication ORDER BY application_name;"
 application_name |   state   | sent_lsn  | replay_lsn | replay_lag_bytes 
------------------+-----------+-----------+------------+------------------
 sba              | streaming | 0/4065890 | 0/4065890  |                0
 sbb              | streaming | 0/4065890 | 0/40656B0  |              480
(2 rows)


$ psql@sbb -c "SELECT pg_last_wal_receive_lsn() AS received, pg_last_wal_replay_lsn() AS replayed, pg_wal_lsn_diff(pg_last_wal_receive_lsn(), pg_last_wal_replay_lsn()) AS unreplayed_bytes;"
 received  | replayed  | unreplayed_bytes 
-----------+-----------+------------------
 0/4065890 | 0/40656B0 |              480
(1 row)


--- step 8: nothing was lost. Resume replay and the comment arrives. ---

$ psql@sbb -c "SELECT pg_wal_replay_resume();"
 pg_wal_replay_resume 
----------------------
 
(1 row)


$ psql@sbb -c "SELECT id, author, body FROM comments;"
 id | author |                body                
----+--------+------------------------------------
  1 | user7  | sentinel-9f4c22 — posted by user 7
(1 row)


